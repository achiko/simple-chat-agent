# generate with: openssl rand -base64 32
AUTH_SECRET=

# OpenAI direct — used by the worker for streamText + image generation
OPENAI_API_KEY=

# Optional: Vercel AI Gateway proxy (template default). Leave empty for direct OpenAI.
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=

# Local Postgres (docker-compose provides this)
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/chatui

# Local Redis (docker-compose provides this) — used for BullMQ, Pub/Sub, and resumable-stream
REDIS_URL=redis://localhost:6379

# Optional: Vercel Blob (not needed for MVP)
BLOB_READ_WRITE_TOKEN=

# Per-1M-token pricing (USD) — read by lib/pricing.ts. Tune to current OpenAI pricing.
GPT5_INPUT_PRICE_PER_1M=1.25
GPT5_OUTPUT_PRICE_PER_1M=10.00

# Per-image pricing (USD) for gpt-image-1 at 1024x1024.
GPT_IMAGE_1_PRICE_PER_IMAGE=0.040
